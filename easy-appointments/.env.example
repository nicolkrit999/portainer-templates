# Database credentials
MYSQL_ROOT_PASSWORD=your-root-password-here
MYSQL_DATABASE=easyappointments
MYSQL_USER=eauser
MYSQL_PASSWORD=your-db-password-here

# Host-mapped ports
NGINX_PORT=8080
MYSQL_PORT=3306
PHPMYADMIN_PORT=8081
SWAGGER_UI_PORT=8082
BAIKAL_PORT=8083

# phpMyAdmin upload limit
PMA_UPLOAD_LIMIT=64M

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
