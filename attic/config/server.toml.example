# Must be reachable at the port this compose publishes atticd on (8081 by default).
# Use your NAS's hostname/IP, or your reverse-proxy/tunnel URL if you put one in front.
# Must end with a trailing slash.
listen = "[::]:8080"
allowed-hosts = []
api-endpoint = "http://YOUR_HOST_OR_DOMAIN:8081/"

[database]
# Supplied via ATTIC_SERVER_DATABASE_URL env var (see docker-compose.yml) so the
# Postgres password never lands in this file. Uncomment only for a SQLite fallback.
#url = "sqlite:///var/lib/atticd/db/server.db?mode=rwc"

[storage]
type = "local"
path = "/var/lib/atticd/storage"

[chunking]
nar-size-threshold = 65536
min-size = 16384
avg-size = 65536
max-size = 262144

[compression]
type = "zstd"

[garbage-collection]
interval = "12 hours"

[jwt]
