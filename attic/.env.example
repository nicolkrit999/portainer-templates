# User IDs
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# RS256 secret key for token signing (base64-encoded)
ATTIC_SERVER_TOKEN_RS256_SECRET_BASE64=your-base64-encoded-rs256-secret-here

# Postgres password for the atticd-db service
ATTIC_DB_PASSWORD=your-postgres-password-here

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
DOCKER_DATA_DIR=/opt/docker-data

