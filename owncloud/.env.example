# OwnCloud app settings
APP_VERSION=latest
APP_NAME=owncloud
APP_URL=owncloud.example.com
APP_USER=admin
APP_PASSWORD=your-admin-password-here

# MariaDB credentials
DB_MARIADB_NAME=owncloud
DB_MARIADB_USER=ownclouduser
DB_MARIADB_PASSWORD=your-db-password-here

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
DOCKER_DATA_DIR=/opt/docker-data
