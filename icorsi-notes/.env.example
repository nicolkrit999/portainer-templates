# Timezone (matches NAS and ownCloud; active-hours window uses this)
TZ=Europe/Zurich

# ── ownCloud WebDAV connection (same credentials as icorsi-sync) ─────────────
OWNCLOUD_USER=your-owncloud-username
OWNCLOUD_APP_PASSWORD=your-owncloud-app-password
# Full WebDAV URL including the username path:
OWNCLOUD_WEBDAV_URL=http://owncloud:8080/remote.php/dav/files/your-username
# Trusted domain to send as the HTTP Host header (ownCloud rejects unknown domains).
# Must match OWNCLOUD_DOMAIN in your owncloud .env, e.g. owncloud.nicolkrit.ch
OWNCLOUD_HOST_HEADER=owncloud.example.com
# Base folder - courses.json paths are relative to this
OWNCLOUD_BASE_PATH=University/Supsi/0002-Bachelor/1-year

# ── Discord notification webhook (optional) ─────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here

# ── Scheduling ──────────────────────────────────────────────────────────────
# How often to check for new _icorsi/ material (seconds). Default: 6 h.
NOTES_INTERVAL_SECONDS=21600
# How long to sleep after hitting the Max plan rate/usage limit (seconds). Default: 1 h.
LIMIT_BACKOFF_SECONDS=3600
# Run once on container start before the first sleep interval.
RUN_ON_START=true
# Dry-run mode: list which courses would be noted, invoke nothing.
DRY_RUN=false

# Cost circuit-breaker: halt if claude -p reports any non-zero cost.
# Guards against accidentally having 'extra usage' ON on your Claude account,
# which would cause overages to be billed at API rates.
# Set to false once you have verified that 'extra usage' is OFF -- that toggle
# is the real protection; with it off you cannot be charged extra regardless.
COST_CIRCUIT_BREAKER=true

# ── Active-hours window ──────────────────────────────────────────────────────
# Claude runs ONLY within this local-time window (uses TZ above).
# Empty string = always active.  Overnight ranges (e.g. 23:00-06:00) are supported.
# Default 00:00-03:00 rationale: if a run hits the 5-hour Max limit at 03:00, the
# session resets ~08:00 -- well before a typical morning. A window ending at 07:00
# would push the reset to ~noon if a limit hit at the very end.
ACTIVE_HOURS=00:00-03:00

# Minimum seconds left in the window required to START a new course.
# Prevents starting a course that cannot reach a clean section boundary.
# Default: 1800 (30 min).
MIN_TASK_WINDOW_SECONDS=1800

# Grace period (minutes) before the window end: daemon sends SIGTERM at
# (window_end - WINDOW_GRACE_MINUTES) to let claude write the final status block,
# then SIGKILL at window_end. Because writes are incremental (one section at a time),
# even a hard kill leaves _suggested/_notes.md in a consistent state.
# Default: 10 min.
WINDOW_GRACE_MINUTES=10

# ── Optional: force a specific Claude model ──────────────────────────────────
# Leave empty to use the default model from the subscription.
CLAUDE_MODEL=

# ── Volume base paths ────────────────────────────────────────────────────────
DOCKER_CONFIG_DIR=/volume2/docker

# ── NOTE: ANTHROPIC_API_KEY is intentionally absent ─────────────────────────
# This service uses your Claude Max subscription (OAuth token stored in the
# /root/.claude volume).  The daemon refuses to start if any billing-capable
# credential (ANTHROPIC_API_KEY, ANTHROPIC_AUTH_TOKEN, CLAUDE_CODE_USE_BEDROCK,
# CLAUDE_CODE_USE_VERTEX) is present -- hard startup assertion, not just omission.
#
# If COST_CIRCUIT_BREAKER=true (default), any non-zero total_cost_usd in a
# claude -p result causes the daemon to write /data/HALT and stop. This catches the
# case where 'extra usage' is accidentally ON. Once you have verified it is OFF,
# set COST_CIRCUIT_BREAKER=false to avoid false-positive halts. Remove /data/HALT to resume.
