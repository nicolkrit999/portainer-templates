# Timezone
TZ=America/New_York

# Host user the container drops to (must own the mounted /data dir)
PUID=1000
PGID=1000

# Moodle/iCorsi credentials
# ICORSI_TOKEN + ICORSI_PRIVATETOKEN + ICORSI_USERID seed /data/token.json on first
# start, after which the tool re-mints the token headlessly. KEEP THESE SET: they are
# the only recovery path if token.json is ever lost/corrupted or the token fully lapses
# (container offline > ~2 days across an expiry). Capture all three once via the
# launch.php incognito flow (see README).
ICORSI_TOKEN=your-moodle-webservice-token-here
ICORSI_PRIVATETOKEN=your-moodle-privatetoken-here
ICORSI_USERID=your-moodle-userid-here

# OwnCloud WebDAV connection
OWNCLOUD_USER=your-owncloud-username
OWNCLOUD_APP_PASSWORD=your-owncloud-app-password
OWNCLOUD_WEBDAV_URL=http://owncloud:8080/remote.php/dav/files/your-username
OWNCLOUD_HOST_HEADER=owncloud.example.com
OWNCLOUD_BASE_PATH=Documents/University

# Discord webhook for sync notifications (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here

# Positive heartbeat: GET this URL after each successful run (optional; uptime-kuma / healthchecks.io)
HEARTBEAT_URL=

# Sync behaviour (defaults are usually fine)
SUBFOLDER=_icorsi
INCLUDE_URL_LINKS=true
SAVE_SECTION_INFO=true
SAVE_FORUMS=true
ICORSI_CONCURRENCY=4

# Excluded modules, default to "-"
EXCLUDE_MODULES=
PRUNE_ORPHANS=false
RECON_MAX_PASSES=5
SYNC_INTERVAL_SECONDS=21600
RUN_ON_START=true
DRY_RUN=false

# Volume base path. Data lives at <VOLUME_CONFIG>/icorsi-sync/data (mounted to /data).
VOLUME_CONFIG=/volume2/docker
