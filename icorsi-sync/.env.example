# --- iCorsi / Moodle Web Service token (secret) ---
ICORSI_TOKEN=

# --- ownCloud WebDAV (reached over the shared docker network, local & fast) ---
# The user segment must match the account, e.g. .../files/oc_admin
OWNCLOUD_WEBDAV_URL=http://owncloud:8080/remote.php/dav/files/oc_admin
OWNCLOUD_USER=oc_admin
OWNCLOUD_APP_PASSWORD=
# Trusted domain to send as the Host header when reaching the container directly.
# Without it ownCloud replies HTTP 400 (untrusted domain). e.g. owncloud.nicolkrit.ch
OWNCLOUD_HOST_HEADER=

# Base folder under which courses.json paths are resolved (no leading/trailing slash).
OWNCLOUD_BASE_PATH=University/Supsi

# --- behaviour (optional, shown with defaults) ---
SUBFOLDER=_icorsi
INCLUDE_URL_LINKS=true       # save 'url' modules as .txt link files
SAVE_SECTION_INFO=true       # save labels + section intros as _info.md
SAVE_FORUMS=true             # save forum/announcement posts as .md (read-only, no mark-as-read)
EXCLUDE_MODULES=             # optional opt-out, e.g. "forum,attendance"; empty = fetch from all module types
PRUNE_ORPHANS=false          # true = delete files no longer in the course so there's ONE current copy
                             #        (renames/moves/removals). Confined to _icorsi/; deletes go to ownCloud trash.
RECON_MAX_PASSES=5           # after uploading, retry still-missing files up to N passes (stops early on no progress)
SYNC_INTERVAL_SECONDS=21600
RUN_ON_START=true
DRY_RUN=false

# --- notifications (optional) ---
DISCORD_WEBHOOK_URL=
