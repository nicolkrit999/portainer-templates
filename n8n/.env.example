# Timezone
TZ=America/New_York

# PostgreSQL database
POSTGRES_PASSWORD=your-db-password-here

# n8n configuration
N8N_HOST=n8n.example.com
N8N_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_URL=https://n8n.example.com/

# Optional Discord webhook for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
DOCKER_DATA_DIR=/opt/docker-data
