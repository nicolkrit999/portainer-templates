{
  "name": "RSS Feeds to Discord",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Daily 8AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "url": "https://selfh.st/rss/"
      },
      "id": "rss-selfhst",
      "name": "RSS selfh.st",
      "type": "n8n-nodes-base.rssFeedRead",
      "typeVersion": 1.1,
      "position": [220, -100]
    },
    {
      "parameters": {
        "url": "https://discourse.nixos.org/latest.rss"
      },
      "id": "rss-nixos",
      "name": "RSS NixOS Discourse",
      "type": "n8n-nodes-base.rssFeedRead",
      "typeVersion": 1.1,
      "position": [220, 100]
    },
    {
      "parameters": {},
      "id": "merge-node",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.seenGuids) {\n  staticData.seenGuids = [];\n}\n\nconst seenGuids = new Set(staticData.seenGuids);\nconst newItems = [];\n\nfor (const item of allItems) {\n  const guid = item.json.guid || item.json.id || item.json.link;\n  if (!guid || seenGuids.has(guid)) continue;\n\n  seenGuids.add(guid);\n\n  const source = item.json.creator || item.json['dc:creator'] || \n    (item.json.link?.includes('discourse.nixos.org') ? 'NixOS Discourse' : 'selfh.st');\n\n  const title = (item.json.title || 'No title').substring(0, 256);\n  const link = item.json.link || '';\n  const description = (item.json.contentSnippet || item.json.content || '').replace(/<[^>]*>/g, '').substring(0, 200);\n\n  newItems.push({\n    json: {\n      embeds: [\n        {\n          title: title,\n          url: link,\n          description: description,\n          color: 3447003,\n          footer: {\n            text: source\n          }\n        }\n      ]\n    }\n  });\n}\n\nconst guidsArray = Array.from(seenGuids);\nstaticData.seenGuids = guidsArray.slice(-500);\n\nif (newItems.length === 0) {\n  return [];\n}\n\nreturn newItems;"
      },
      "id": "code-dedup",
      "name": "Deduplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "PASTE_YOUR_DISCORD_WEBHOOK_URL_HERE",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "batching": {
            "batch": {
              "batchSize": 1,
              "batchInterval": 2000
            }
          }
        }
      },
      "id": "discord-post",
      "name": "Post to Discord",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0]
    }
  ],
  "connections": {
    "Daily 8AM": {
      "main": [
        [
          { "node": "RSS selfh.st", "type": "main", "index": 0 },
          { "node": "RSS NixOS Discourse", "type": "main", "index": 0 }
        ]
      ]
    },
    "RSS selfh.st": {
      "main": [
        [
          { "node": "Merge", "type": "main", "index": 0 }
        ]
      ]
    },
    "RSS NixOS Discourse": {
      "main": [
        [
          { "node": "Merge", "type": "main", "index": 1 }
        ]
      ]
    },
    "Merge": {
      "main": [
        [
          { "node": "Deduplicate", "type": "main", "index": 0 }
        ]
      ]
    },
    "Deduplicate": {
      "main": [
        [
          { "node": "Post to Discord", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
