# User IDs
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Admin user
ADMIN_USER=admin

# Public URL (used for both PAPERLESS_URL and CSRF_TRUSTED_ORIGINS)
PAPERLESS_URL=https://paperless.example.com

# Container hostnames
PAPERLESS_REDIS_HOSTNAME=paperlessngx-redis.example.com
PAPERLESS_DB_HOSTNAME=paperlessngx-db.example.com
PAPERLESS_GOTENBERG_HOSTNAME=paperlessngx-gotenberg.example.com
PAPERLESS_TIKA_HOSTNAME=paperlessngx-tika.example.com
PAPERLESS_APP_HOSTNAME=paperlessngx.example.com

# Secrets
PAPERLESS_REDIS_PASSWORD=your-redis-password-here
POSTGRES_PASSWORD=your-postgres-password-here
PAPERLESS_DBPASS=your-db-password-here
PAPERLESS_ADMIN_PASSWORD=your-admin-password-here

# Volume base paths
DOCKER_DATA_DIR=/opt/docker-data
