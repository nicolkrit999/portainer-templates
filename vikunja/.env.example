# Timezone
TZ=America/New_York

# User IDs
PUID=1000
PGID=1000

# Mailer settings
VIKUNJA_MAILER_HOST=smtp.gmail.com
VIKUNJA_MAILER_PORT=587

# Mailer credentials
VIKUNJA_MAILER_USERNAME=your-smtp-username@gmail.com
VIKUNJA_MAILER_PASSWORD=your-smtp-app-password
VIKUNJA_MAILER_FROMEMAIL=noreply@example.com

# JWT secret (random 32+ character string)
VIKUNJA_SERVICE_JWTSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL
VIKUNJA_SERVICE_PUBLICURL=https://tasks.example.com

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
