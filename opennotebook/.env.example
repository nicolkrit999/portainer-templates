# Open Notebook - environment variable reference
# Copy this file to .env (gitignored) and fill in real values,
# or configure these variables directly in Portainer's stack env editor.

# ── Host data paths ───────────────────────────────────────────────────────────
# SurrealDB lives on the SSD pool (fast DB access); notebook content lives on the
# HDD pool (PDFs, audio, podcasts can grow large). Each gets one subfolder.
OPENNOTEBOOK_DB_ROOT=/volume2/docker/opennotebook
OPENNOTEBOOK_DATA_ROOT=/volume1/Default-volume-1/0001_Docker/opennotebook

# ── Public URL ────────────────────────────────────────────────────────────────
# The external HTTPS URL the browser uses. Next.js proxies /api/* to the backend
# internally, so only this one origin needs to be reachable. MUST be https://.
OPENNOTEBOOK_PUBLIC_URL=https://opennotebook.nicolkrit.ch

# ── SurrealDB credentials ─────────────────────────────────────────────────────
# Username and password for the embedded SurrealDB instance.
SURREAL_USER=changeme
SURREAL_PASSWORD=changeme

# ── Open Notebook encryption ──────────────────────────────────────────────────
# 32-byte (256-bit) random key used to encrypt notebook data at rest.
# Generate with: openssl rand -hex 32
OPEN_NOTEBOOK_ENCRYPTION_KEY=changeme

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Zurich
