# Open Notebook - environment variable reference
# Copy this file to .env (gitignored) and fill in real values,
# or configure these variables directly in Portainer's stack env editor.

# ── SurrealDB credentials ─────────────────────────────────────────────────────
# Username and password for the embedded SurrealDB instance.
SURREAL_USER=changeme
SURREAL_PASSWORD=changeme

# ── Open Notebook encryption ──────────────────────────────────────────────────
# 32-byte (256-bit) random key used to encrypt notebook data at rest.
# Generate with: openssl rand -hex 32
OPEN_NOTEBOOK_ENCRYPTION_KEY=changeme

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Zurich
