# Uptime Kuma integration
UPTIME_KUMA_URL=http://uptime-kuma:3001
UPTIME_KUMA_PUBLIC_URL=https://uptime-kuma.example.com
UPTIME_KUMA_STATUS_SLUG=my-status-page

# Immich integration
IMMICH_URL=immich_server:2283
IMMICH_API_KEY=your-immich-api-key-here

# Beszel integration
BESZEL_URL=beszel:8090
BESZEL_TOKEN=your-beszel-token-here

# Jellyfin integration
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_PUBLIC_URL=https://jellyfin.example.com
JELLYFIN_KEY=your-jellyfin-api-key-here

# Kavita integration
KAVITA_URL=http://kavita:5000
KAVITA_PUBLIC_URL=https://kavita.example.com
KAVITA_KEY=your-kavita-api-key-here

# Audiobookshelf integration
AUDIOBOOKSHELF_URL=http://audiobookshelf:80
AUDIOBOOKSHELF_PUBLIC_URL=https://audiobooks.example.com
AUDIOBOOKSHELF_KEY=your-audiobookshelf-api-key-here

# Google Calendar integration (optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
