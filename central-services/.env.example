# LDAP organisation and domain
LDAP_ORGANISATION=My Organisation
LDAP_DOMAIN=example.com
LDAP_BASE_DN=dc=example,dc=com

# LDAP admin credentials
LDAP_ADMIN_USERNAME=admin
LDAP_ADMIN_PASSWORD=your-admin-password-here
LDAP_CONFIG_PASSWORD=your-config-password-here

# Read-only user (set LDAP_READONLY_USER_ENABLED=true to activate)
LDAP_READONLY_USER_ENABLED=false
LDAP_READONLY_USER_USERNAME=readonly
LDAP_READONLY_USER_PASSWORD=your-readonly-password-here

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
