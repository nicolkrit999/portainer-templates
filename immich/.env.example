# User IDs
PUID=1000
PGID=1000

# Immich version tag (leave empty to use "release")
IMMICH_VERSION=

# Database credentials
DB_USERNAME=immich
DB_PASSWORD=your-db-password-here
DB_DATABASE_NAME=immich

# Storage paths
UPLOAD_LOCATION=/opt/docker-data/immich/uploads
DB_DATA_LOCATION=/opt/docker-data/immich/postgres

# Public server URL
PUBLIC_IMMICH_SERVER_URL=https://immich.example.com

# Volume base paths
DOCKER_CONFIG_DIR=/opt/docker
DOCKER_DATA_DIR=/opt/docker-data
