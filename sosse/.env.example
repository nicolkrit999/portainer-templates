# Timezone
TZ=America/New_York

# Container hostname for the database
SOSSE_DB_HOSTNAME=sosse-db.example.com

# Secrets
POSTGRES_PASSWORD=your-postgres-password-here
SOSSE_DB_PASS=your-sosse-db-password-here
SOSSE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Volume base paths
DOCKER_DATA_DIR=/opt/docker-data
