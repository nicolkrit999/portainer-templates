DOCKER_DATA_DIR=/opt/docker-data
TZ=Europe/London
PUID=1000
PGID=1000

# Mealie service URL
MEALIE_BASE_URL=https://mealie.example.com

# OIDC / SSO configuration
OIDC_CLIENT_ID=your-oidc-client-id-here
OIDC_CLIENT_SECRET=your-oidc-client-secret-here
OIDC_CONFIGURATION_URL=https://your-oidc-provider.example.com/.well-known/openid-configuration
