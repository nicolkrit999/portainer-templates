# Timezone
TZ=America/New_York

# Gotify notification URL
GOTIFY_URL=http://gotify:80/

# Comma-separated list of container names to exclude from updates
WATCHTOWER_DISABLE_CONTAINERS=container-name-1,container-name-2

# Hostname shown in Watchtower notifications
WATCHTOWER_NOTIFICATIONS_HOSTNAME=watchtower.example.com

# Gotify app token for notifications
WATCHTOWER_NOTIFICATION_GOTIFY_TOKEN=your-gotify-token-here
