TZ=UTC
COOLIFY_DATA_ROOT=/path/to/coolify/data

# Coolify image version (leave as 'latest' to always pull newest)
COOLIFY_VERSION=latest

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Coolify
APP_ENV=production

# Random 32-char hex:  openssl rand -hex 16
APP_ID=

# Laravel app key - must be prefixed with "base64:":  echo "base64:$(openssl rand -base64 32)"
APP_KEY=

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_USERNAME=coolify
DB_DATABASE=coolify

# Strong password:  openssl rand -base64 24
DB_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Strong password:  openssl rand -base64 24
REDIS_PASSWORD=

# ── Realtime / WebSocket (Soketi) ─────────────────────────────────────────────
# Random ID:        openssl rand -hex 8
PUSHER_APP_ID=

# Random key:       openssl rand -hex 16
PUSHER_APP_KEY=

# Random secret:    openssl rand -base64 32
PUSHER_APP_SECRET=

SOKETI_PORT=6001
SOKETI_METRICS_PORT=6002
SOKETI_DEBUG=false

# ── Initial admin account ─────────────────────────────────────────────────────
ROOT_USERNAME=admin
ROOT_USER_EMAIL=you@example.com
ROOT_USER_PASSWORD=

# ── PHP-FPM tuning (defaults are fine for most setups) ───────────────────────
PHP_MEMORY_LIMIT=256M
PHP_FPM_PM_CONTROL=dynamic
PHP_FPM_PM_START_SERVERS=1
PHP_FPM_PM_MIN_SPARE_SERVERS=1
PHP_FPM_PM_MAX_SPARE_SERVERS=10
