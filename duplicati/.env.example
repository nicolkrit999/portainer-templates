# Timezone (note: PUID/PGID are intentionally 0/root for full backup access)
TZ=America/New_York

# Duplicati encryption and web UI password
DUPLICATI_SETTINGS_ENCRYPTION_KEY=your-settings-encryption-key-here
DUPLICATI_WEBSERVICE_PASSWORD=your-web-ui-password-here

# Volume base path for config
DOCKER_CONFIG_DIR=/opt/docker

# Source mounts — adjust to your filesystem layout
DUPLICATI_HOME_SOURCE=/home
DUPLICATI_SOURCE1=/mnt/volume1
DUPLICATI_SOURCE2=/mnt/volume2
DUPLICATI_RESTORE_TEMP=/tmp/duplicati-restore
